@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/ontology#> .

### Classes ###
:AI_System a owl:Class ;
    rdfs:label "AI System" .

:Regulation a owl:Class ;
    rdfs:label "Regulation" .

:Deployer a owl:Class ;
    rdfs:label "Deployer" .

:Provider a owl:Class ;
    rdfs:label "Provider" .

:Data a owl:Class ;
    rdfs:label "Data" .

:Data_Governance a owl:Class ;
    rdfs:label "Data Governance" .

:Human_Oversight a owl:Class ;
    rdfs:label "Human Oversight" .

:Accuracy a owl:Class ;
    rdfs:label "Accuracy" .

:Robustness a owl:Class ;
    rdfs:label "Robustness" .

:Cybersecurity a owl:Class ;
    rdfs:label "Cybersecurity" .

:Authority a owl:Class ;
    rdfs:label "Authority" .

:Notified_Body a owl:Class ;
    rdfs:label "Notified Body" .

:Conformity_Assessment a owl:Class ;
    rdfs:label "Conformity Assessment" .

:Systemic_Risk a owl:Class ;
    rdfs:label "Systemic Risk" .

:Enforcement a owl:Class ;
    rdfs:label "Enforcement" .

:Code_of_Conduct a owl:Class ;
    rdfs:label "Code of Conduct" .

:Innovation a owl:Class ;
    rdfs:label "Innovation" .

:Small_Business a owl:Class ;
    rdfs:label "Small Business" .

:Start-up a owl:Class ;
    rdfs:label "Start-up" .

### Object Properties ###
:compliesWith a owl:ObjectProperty ;
    rdfs:label "compliesWith" ;
    rdfs:comment "Defines compliance relationship with a regulation" .

:transparency a owl:ObjectProperty ;
    rdfs:label "transparency" ;
    rdfs:comment "Defines transparency relationship with a regulation" .

:provisionOfInformation a owl:ObjectProperty ;
    rdfs:label "provisionOfInformation" ;
    rdfs:comment "Defines provision of information relationship with a regulation" .

:manages a owl:ObjectProperty ;
    rdfs:label "manages" ;
    rdfs:comment "Defines management relationship with data" .

:obligations a owl:ObjectProperty ;
    rdfs:label "obligations" ;
    rdfs:comment "Defines obligations relationship with a deployer or provider" .

:coordinatesWith a owl:ObjectProperty ;
    rdfs:label "coordinatesWith" ;
    rdfs:comment "Defines coordination relationship with an authority or notified body" .

:enforces a owl:ObjectProperty ;
    rdfs:label "enforces" ;
    rdfs:comment "Defines enforcement relationship" .

:developsAndImplements a owl:ObjectProperty ;
    rdfs:label "developsAndImplements" ;
    rdfs:comment "Defines development and implementation relationship" .

:supports a owl:ObjectProperty ;
    rdfs:label "supports" ;
    rdfs:comment "Defines support relationship for innovation, small businesses, or start-ups" .

### Data Properties ###
:url a owl:DatatypeProperty ;
    rdfs:label "url" ;
    rdfs:comment "Defines the URL of a resource" .

:regulation a owl:DatatypeProperty ;
    rdfs:label "regulation" ;
    rdfs:comment "Defines the regulation associated with an article" .

:citation a owl:DatatypeProperty ;
    rdfs:label "citation" ;
    rdfs:comment "Defines the citation of a regulation" .

:source_url a owl:DatatypeProperty ;
    rdfs:label "source_url" ;
    rdfs:comment "Defines the source URL of a resource" .

:scraped_at a owl:DatatypeProperty ;
    rdfs:label "scraped_at" ;
    rdfs:comment "Defines the timestamp when the data was scraped" .

