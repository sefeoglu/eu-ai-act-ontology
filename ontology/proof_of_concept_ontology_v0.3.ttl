###  http://example.org/eu-ai-act#affected_applicant_population
eu_ai_act:affected_applicant_population rdf:type owl:NamedIndividual ,
                                                 eu_ai_act:affected_person_group ;
                                        rdfs:comment "Representative affected person group. Source: Generated from provided triples." ;
                                        rdfs:label "Affected applicant population" .


###  http://example.org/eu-ai-act#ai_office_instance
eu_ai_act:ai_office_instance rdf:type owl:NamedIndividual ,
                                      eu_ai_act:ai_office ;
                             eu_ai_act:coordinates_enforcement "true"^^xsd:boolean ;
                             eu_ai_act:supports_implementation "true"^^xsd:boolean ;
                             rdfs:comment "Representative AI Office individual. Source: Generated from provided triples." ;
