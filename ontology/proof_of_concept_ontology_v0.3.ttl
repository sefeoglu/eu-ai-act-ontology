#################################################################
#    Annotations
#################################################################

eu_ai_act:adverse_outcome rdfs:comment "A harmful or negative result caused or influenced by an AI system. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                          rdfs:label "Adverse outcome" .


eu_ai_act:applies_bias_mitigation_measure rdfs:comment "Indicates that a bias mitigation measure is applied. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                                          rdfs:label "applies bias mitigation measure" .


eu_ai_act:coordinates_enforcement rdfs:comment "Indicates that a governance body helps coordinate enforcement across Member States. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                                  rdfs:label "coordinates enforcement" .


eu_ai_act:fundamental_rights_risk rdfs:comment "A risk of adverse impact on fundamental rights. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                                  rdfs:label "Fundamental rights risk" .


eu_ai_act:harm rdfs:comment "Adverse impact on health, safety, or fundamental rights caused or likely to be caused by an AI practice. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
               rdfs:label "Harm" .


eu_ai_act:has_accuracy_score rdfs:comment "Links an accuracy, robustness and cybersecurity concept to a literal accuracy score. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ,
                                          "Literal accuracy score. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                             rdfs:label "has accuracy score" .


eu_ai_act:has_adaptiveness_value rdfs:comment "Links an AI system to a literal adaptiveness value. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ,
                                              "Literal adaptiveness value. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                                 rdfs:label "has adaptiveness value" .


eu_ai_act:has_article_number rdfs:comment "Links an article to a literal article number. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ,
                                          "Literal article number. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                             rdfs:label "has article number" .


eu_ai_act:has_autonomy_level_value rdfs:comment "Links an AI system to a literal autonomy level value. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ,
                                                "Literal autonomy level value. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
                                   rdfs:label "has autonomy level value" .


eu_ai_act:has_citation rdfs:comment "Formal citation of the regulation. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ,
                                    "Links a regulation to its formal citation. Source: Regulation (EU) 2024/1689; https://artificialintelligenceact.eu/ai-act-explorer/." ;
